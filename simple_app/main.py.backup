from fastapi import FastAPI, Depends, Body
from fastapi.responses import HTMLResponse, JSONResponse
from pydantic import BaseModel
from sqlmodel import SQLModel, Field, create_engine, Session, select
from sqlalchemy import or_
from datetime import datetime
from typing import Optional, List
import httpx, json, os

app = FastAPI()

# === DB Config ===
DATABASE_URL = "postgresql://quicknote:quicknote123@localhost:5432/quicknote_db"
engine = create_engine(DATABASE_URL)

def get_session():
    with Session(engine) as session:
        yield session

class Note(SQLModel, table=True):
    __tablename__ = "notes"
    id: Optional[int] = Field(default=None, primary_key=True)
    content: str = Field(max_length=2000)
    tags: str
    insight: str
    created_at: datetime = Field(default_factory=datetime.utcnow)

@app.on_event("startup")
def on_startup():
    SQLModel.metadata.create_all(engine)

# === OLLAMA LLM CONFIG ===
OLLAMA_URL = "http://127.0.0.1:11434/v1/chat/completions"
OLLAMA_MODEL = "qwen2.5:1.5b"

async def llm_call(prompt: str, temp: float = 0.2, max_tokens: int = 150) -> str:
    """Универсальный вызов к Ollama"""
    try:
        async with httpx.AsyncClient() as c:
            r = await c.post(OLLAMA_URL, json={
                "model": OLLAMA_MODEL,
                "messages": [{"role": "user", "content": prompt}],
                "temperature": temp,
                "max_tokens": max_tokens
            }, headers={"Content-Type": "application/json"}, timeout=30)
            r.raise_for_status()
            return r.json()["choices"][0]["message"]["content"].strip()
    except Exception as e:
        print(f"⚠️ Ollama Error: {e}")
        return ""

async def llm_generate_tags(text: str) -> List[str]:
    """Генерирует 3 хештега через LLM"""
    prompt = f"Return ONLY a JSON array of exactly 3 relevant Russian hashtags for this note. No explanation, no markdown. Note: {text}"
    raw = await llm_call(prompt, temp=0.1, max_tokens=50)
    try:
        # Чистим ответ от markdown если есть
        clean = raw.replace("```json", "").replace("```", "").strip()
        tags = json.loads(clean)
        return tags if isinstance(tags, list) and len(tags) == 3 else ["заметка", "общее", "идея"]
    except:
        # Fallback на правила если JSON не распарсился
        t = text.lower()
        if any(w in t for w in ["встреча","созвон","ментор"]): return ["встреча","работа","коммуникация"]
        if any(w in t for w in ["дедлайн","лаба","сдать"]): return ["учеба","дедлайн","срочно"]
        if any(w in t for w in ["идея","план","хочу"]): return ["идея","планирование","креатив"]
        return ["заметка", "общее", "идея"]

async def llm_generate_insight(text: str, tags: List[str]) -> str:
    """Генерирует персонализированный инсайт"""
    prompt = f"Note: \"{text}\". Tags: {tags}. Give ONE short helpful tip or reminder in Russian. Max 15 words. No markdown."
    raw = await llm_call(prompt, temp=0.4, max_tokens=80)
    return raw if raw else "💡 Совет: дополните заметку деталями для лучшего поиска."

async def llm_smart_search(query: str, notes_context: str) -> str:
    """Контекстный ответ на поисковый запрос"""
    prompt = f"User asked: \"{query}\"\nFound notes:\n{notes_context}\n\nAnswer in Russian: summarize what was found and add 1 helpful tip. Keep under 3 sentences. No markdown."
    raw = await llm_call(prompt, temp=0.3, max_tokens=200)
    return raw if raw else f"🔍 Найдено записей: {notes_context.count('-')}"

# === ENDPOINTS ===
class NoteRequest(BaseModel): content: str

@app.post("/api/process")
async def process_note( NoteRequest, session: Session = Depends(get_session)):
    tags = await llm_generate_tags(data.content)
    insight = await llm_generate_insight(data.content, tags)
    note = Note(content=data.content, tags=",".join(tags), insight=insight)
    session.add(note)
    session.commit()
    session.refresh(note)
    return {"success": True, "id": note.id, "tags": tags, "insight": insight, "original": data.content[:200]}

@app.post("/api/search")
async def search_notes(query_data: dict = Body(), session: Session = Depends(get_session)):
    query = query_data.get("query", "").strip()
    if len(query) < 2:
        return {"success": False, "message": "Введите минимум 2 символа"}
    
    keywords = [w for w in query.lower().split() if len(w) > 2]
    if not keywords: keywords = [query.lower()]
    
    conditions = [Note.content.ilike(f"%{kw}%") for kw in keywords]
    conditions += [Note.tags.ilike(f"%{kw}%") for kw in keywords]
    
    stmt = select(Note).where(or_(*conditions)).order_by(Note.created_at.desc()).limit(5)
    notes = session.exec(stmt).all()
    
    if not notes:
        return {"success": False, "message": "🔍 Ничего не нашёл. Попробуйте уточнить запрос."}
    
    context = "\n".join([f"- [{n.created_at.strftime('%d.%m')}] {n.content}" for n in notes])
    answer = await llm_smart_search(query, context)
    
    return {
        "success": True,
        "answer": answer,
        "notes": [{"id": n.id, "content": n.content, "tags": n.tags.split(","), "created_at": n.created_at.isoformat()} for n in notes]
    }

@app.get("/api/history")
async def get_history(limit: int = 10, session: Session = Depends(get_session)):
    stmt = select(Note).order_by(Note.created_at.desc()).limit(limit)
    notes = session.exec(stmt).all()
    return [{"id": n.id, "content": n.content, "tags": n.tags.split(","), "insight": n.insight, "created_at": n.created_at.isoformat()} for n in notes]

@app.get("/health")
async def health(): 
    return {"status": "ok", "db": "postgresql", "llm": "ollama:qwen2.5:1.5b"}

# === HTML Frontend ===
HTML = """<!DOCTYPE html><html><head><meta charset="UTF-8"><title>✨ QuickNote AI</title>
<style>body{font-family:system-ui,sans-serif;max-width:800px;margin:40px auto;padding:20px;background:#f8f9fa}.card{background:white;padding:24px;border-radius:12px;box-shadow:0 2px 8px rgba(0,0,0,0.1);margin-bottom:20px}.input-group{display:flex;gap:10px;margin-bottom:10px}textarea{flex:1;min-height:80px;padding:12px;border:2px solid #e0e0e0;border-radius:8px;font-size:16px;resize:none}input[type="text"]{flex:1;padding:12px;border:2px solid #e0e0e0;border-radius:8px;font-size:16px}button{background:#4f46e5;color:white;border:none;padding:12px 20px;border-radius:8px;font-size:16px;cursor:pointer;white-space:nowrap}button:hover{background:#4338ca}.result{margin-top:15px;padding:16px;background:#f0f9ff;border-radius:8px;display:none}.result.show{display:block}.tags{display:flex;gap:8px;flex-wrap:wrap;margin:8px 0}.tag{background:#e0e7ff;color:#3730a3;padding:4px 12px;border-radius:20px;font-size:14px}.note-item{padding:12px;border-bottom:1px solid #e5e7eb}.note-item:last-child{border-bottom:none}h1,h2{margin:0 0 15px}.loading{color:#6b7280;font-style:italic}</style></head>
<body>
<div class="card"><h1>✨ QuickNote AI</h1><p style="color:#6b7280;margin:-10px 0 15px">🧠 Работает на локальной LLM (Ollama)</p><div class="input-group"><textarea id="content" placeholder="Введите заметку..."></textarea><button id="saveBtn" onclick="saveNote()">💾 Сохранить</button></div><div class="result" id="saveResult"><div><strong>🏷️ Теги:</strong><div class="tags" id="tags"></div></div><div style="margin-top:10px"><strong>💡 Инсайт:</strong><p id="insight"></p></div></div></div>

<div class="card"><h2>🔍 Умный поиск</h2><div class="input-group"><input type="text" id="searchQuery" placeholder="Например: база данных, дедлайн..."><button id="searchBtn" onclick="searchNotes()">🔎 Найти</button></div><div class="result" id="searchResult" style="white-space:pre-line"></div><div id="searchNotesList"></div></div>

<div class="card"><h2>📚 История</h2><div id="history"><span class="loading">Загрузка...</span></div></div>

<script>
async function saveNote(){
  const c=document.getElementById("content").value.trim();
  const btn=document.getElementById("saveBtn");
  if(!c)return alert("Введите текст");
  btn.disabled=true; btn.innerText="⏳ Думаем...";
  document.getElementById("saveResult").classList.remove("show");
  try{
    const r=await fetch("/api/process",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({content:c})});
    const d=await r.json();
    console.log("Save response:",d);
    if(!d.success){alert("Ошибка: "+(d.detail||"Неизвестная ошибка"));return;}
    if(!d.tags||!Array.isArray(d.tags)){alert("Неверный формат ответа");return;}
    document.getElementById("tags").innerHTML=d.tags.map(t=>"<span class='tag'>#"+t+"</span>").join(" ");
    document.getElementById("insight").innerText=d.insight||"💡 Инсайт недоступен";
    document.getElementById("saveResult").classList.add("show");
    document.getElementById("content").value="";
    loadHistory();
  }catch(e){
    console.error("Save error:",e);
    alert("Ошибка сохранения: "+e.message);
  }
  finally{btn.disabled=false; btn.innerText="💾 Сохранить"}
}

async function searchNotes(){
  const q=document.getElementById("searchQuery").value.trim();
  const btn=document.getElementById("searchBtn");
  if(!q)return alert("Введите запрос");
  btn.disabled=true; btn.innerText="⏳ Ищем...";
  document.getElementById("searchResult").classList.remove("show");
  document.getElementById("searchNotesList").innerHTML="<span class='loading'>Анализируем заметки...</span>";
  try{
    const r=await fetch("/api/search",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({query:q})});
    const d=await r.json();
    if(!d.success){document.getElementById("searchResult").innerText="🔍 "+d.message;document.getElementById("searchResult").classList.add("show");return}
    document.getElementById("searchResult").innerText=d.answer;
    document.getElementById("searchResult").classList.add("show");
    let html="";d.notes.forEach(n=>{html+="<div class='note-item'><strong>["+n.tags.join(",")+"]</strong><br>"+n.content+"</div>"});
    document.getElementById("searchNotesList").innerHTML=html;
  }catch(e){alert("Ошибка: "+e.message)}
  finally{btn.disabled=false; btn.innerText="🔎 Найти"}
}

async function loadHistory(){
  try{
    const r=await fetch("/api/history");
    const d=await r.json();
    console.log("History:",d);
    if(!Array.isArray(d)){document.getElementById("history").innerHTML="<span class='loading'>Ошибка загрузки</span>";return;}
    let h="";d.forEach(n=>{
      const tags=Array.isArray(n.tags)?n.tags.join(","):"";
      h+="<div class='note-item'><strong>#" +n.id+" ["+tags+"]</strong><br>"+(n.content||"").substring(0,100)+"</div>";
    });
    document.getElementById("history").innerHTML=h||"<span class='loading'>Пока пусто</span>";
  }catch(e){
    console.error("History error:",e);
    document.getElementById("history").innerHTML="<span class='loading'>Ошибка загрузки</span>";
  }
}
loadHistory();
</script></body></html>"""

@app.get("/", response_class=HTMLResponse)
async def home(): return HTML
