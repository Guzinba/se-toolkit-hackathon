from fastapi import FastAPI, Depends, Body, HTTPException
from fastapi.responses import HTMLResponse, JSONResponse
from pydantic import BaseModel
from sqlmodel import SQLModel, Field, create_engine, Session, select
from sqlalchemy import or_
from datetime import datetime
from typing import Optional, List
import httpx, json, os

app = FastAPI()

# === DB Config ===
DATABASE_URL = "postgresql://quicknote:quicknote123@localhost:5432/quicknote_db"
engine = create_engine(DATABASE_URL)

def get_session():
    with Session(engine) as session:
        yield session

# === FIXED TAGS SYSTEM ===
AVAILABLE_TAGS = {
    "учеба": ["лекция", "семинар", "лабораторная", "экзамен", "тест", "домашка", "конспект", "теория"],
    "планы": ["встреча", "дедлайн", "срок", "план", "задача", "цель", "напоминание"],
    "работа": ["проект", "ментор", "команда", "демо", "презентация", "отчёт"],
    "идеи": ["идея", "креатив", "стартап", "предложение", "инсайт"],
    "личное": ["здоровье", "спорт", "хобби", "путешествие", "покупки"],
    "важно": ["срочно", "приоритет", "критично"]
}

ALL_TAGS = list(AVAILABLE_TAGS.keys())

class Note(SQLModel, table=True):
    __tablename__ = "notes"
    id: Optional[int] = Field(default=None, primary_key=True)
    title: str = Field(max_length=200, default="Без заголовка")
    content: str = Field(max_length=5000)
    tags: str  # JSON array
    insight: str
    created_at: datetime = Field(default_factory=datetime.utcnow)

@app.on_event("startup")
def on_startup():
    SQLModel.metadata.create_all(engine)

# === OLLAMA LLM ===
OLLAMA_URL = "http://127.0.0.1:11434/v1/chat/completions"
OLLAMA_MODEL = "qwen2.5:1.5b"

async def llm_call(prompt: str, temp: float = 0.2, max_tokens: int = 200) -> str:
    try:
        async with httpx.AsyncClient(timeout=30) as c:
            r = await c.post(OLLAMA_URL, json={
                "model": OLLAMA_MODEL,
                "messages": [{"role": "user", "content": prompt}],
                "temperature": temp,
                "max_tokens": max_tokens
            }, headers={"Content-Type": "application/json"}, timeout=30)
            r.raise_for_status()
            return r.json()["choices"][0]["message"]["content"].strip()
    except Exception as e:
        print(f"⚠️ Ollama Error: {e}")
        return ""

def generate_title(text: str) -> str:
    """Генерирует заголовок из первых 5-7 слов"""
    words = text.strip().split()[:7]
    title = " ".join(words)
    if len(title) > 100:
        title = title[:97] + "..."
    return title if title else "Без заголовка"

def suggest_tags_from_text(text: str) -> List[str]:
    """Предлагает теги на основе ключевых слов"""
    t = text.lower()
    suggested = []
    
    for category, keywords in AVAILABLE_TAGS.items():
        if any(kw in t for kw in keywords):
            suggested.append(category)
    
    # Добавляем временные теги
    if "завтра" in t or "сегодня" in t or "неделя" in t:
        suggested.append("планы")
    
    return list(dict.fromkeys(suggested))[:5]  # Уникальные, максимум 5

async def llm_generate_insight(text: str, tags: List[str]) -> str:
    prompt = f"Note: \"{text[:300]}\". Tags: {tags}. Give ONE short helpful tip in Russian. Max 15 words."
    raw = await llm_call(prompt, temp=0.4, max_tokens=80)
    return raw if raw else "💡 Совет: дополните заметку деталями."

async def llm_smart_search(query: str, notes_context: str) -> str:
    prompt = f"User asked: \"{query}\"\nFound notes:\n{notes_context}\n\nAnswer in Russian: summarize and add 1 tip. Under 3 sentences."
    raw = await llm_call(prompt, temp=0.3, max_tokens=200)
    return raw if raw else f"🔍 Найдено записей: {notes_context.count('-')}"

# === ENDPOINTS ===
class NoteRequest(BaseModel): content: str

@app.get("/api/tags")
async def get_available_tags():
    """Возвращает все доступные теги"""
    return {"tags": ALL_TAGS, "categories": AVAILABLE_TAGS}

@app.post("/api/process")
async def process_note( NoteRequest, session: Session = Depends(get_session)):
    # Генерируем заголовок
    title = generate_title(data.content)
    
    # Предлагаем теги (rule-based)
    suggested_tags = suggest_tags_from_text(data.content)
    
    # Генерируем инсайт
    insight = await llm_generate_insight(data.content, suggested_tags)
    
    # Сохраняем
    note = Note(
        title=title,
        content=data.content,
        tags=json.dumps(suggested_tags),
        insight=insight
    )
    session.add(note)
    session.commit()
    session.refresh(note)
    
    return {
        "success": True, 
        "id": note.id, 
        "title": title,
        "content": data.content,
        "tags": suggested_tags,
        "insight": insight
    }

@app.post("/api/update-tags")
async def update_note_tags( NoteRequest, session: Session = Depends(get_session)):
    """Обновляет теги заметки после валидации пользователем"""
    try:
        data_dict = json.loads(data.content)
        note_id = data_dict["id"]
        new_tags = data_dict["tags"]
        
        # Валидация
        if not isinstance(new_tags, list) or len(new_tags) > 5:
            raise HTTPException(status_code=400, detail="Неверный формат тегов")
        
        for tag in new_tags:
            if tag not in ALL_TAGS:
                raise HTTPException(status_code=400, detail=f"Недопустимый тег: {tag}")
        
        # Обновляем
        note = session.get(Note, note_id)
        if not note:
            raise HTTPException(status_code=404, detail="Заметка не найдена")
        
        note.tags = json.dumps(new_tags)
        session.commit()
        session.refresh(note)
        
        return {"success": True, "tags": new_tags}
    except json.JSONDecodeError:
        raise HTTPException(status_code=400, detail="Неверный JSON")

@app.get("/api/notes/{note_id}")
async def get_note(note_id: int, session: Session = Depends(get_session)):
    """Получает одну заметку для просмотра"""
    note = session.get(Note, note_id)
    if not note:
        raise HTTPException(status_code=404, detail="Заметка не найдена")
    
    return {
        "id": note.id,
        "title": note.title,
        "content": note.content,
        "tags": json.loads(note.tags) if note.tags else [],
        "insight": note.insight,
        "created_at": note.created_at.isoformat()
    }

@app.get("/api/notes")
async def get_all_notes(limit: int = 50, session: Session = Depends(get_session)):
    """Получает все заметки (для истории)"""
    stmt = select(Note).order_by(Note.created_at.desc()).limit(limit)
    notes = session.exec(stmt).all()
    return [{
        "id": n.id,
        "title": n.title,
        "content": n.content,
        "tags": json.loads(n.tags) if n.tags else [],
        "insight": n.insight,
        "created_at": n.created_at.isoformat()
    } for n in notes]

@app.post("/api/search")
async def search_notes(query_data: dict = Body(), session: Session = Depends(get_session)):
    query = query_data.get("query", "").strip()
    if len(query) < 2:
        return {"success": False, "message": "Введите минимум 2 символа"}
    
    keywords = [w for w in query.lower().split() if len(w) > 2]
    if not keywords: keywords = [query.lower()]
    
    conditions = [Note.content.ilike(f"%{kw}%") for kw in keywords]
    conditions += [Note.title.ilike(f"%{kw}%") for kw in keywords]
    
    stmt = select(Note).where(or_(*conditions)).order_by(Note.created_at.desc()).limit(5)
    notes = session.exec(stmt).all()
    
    if not notes:
        return {"success": False, "message": "🔍 Ничего не нашёл."}
    
    context = "\n".join([f"- [{n.title}] {n.content[:100]}" for n in notes])
    answer = await llm_smart_search(query, context)
    
    return {
        "success": True,
        "answer": answer,
        "notes": [{
            "id": n.id, 
            "title": n.title, 
            "content": n.content, 
            "tags": json.loads(n.tags) if n.tags else [],
            "created_at": n.created_at.isoformat()
        } for n in notes]
    }

@app.get("/health")
async def health(): 
    return {"status": "ok", "db": "postgresql", "llm": "ollama:qwen2.5:1.5b", "tags": "fixed"}

# === HTML Frontend ===
HTML = """<!DOCTYPE html><html><head><meta charset="UTF-8"><title>QuickNote AI</title>
<style>
*{box-sizing:border-box}
body{font-family:system-ui,sans-serif;max-width:900px;margin:0 auto;padding:20px;background:#f8f9fa}
.card{background:white;padding:24px;border-radius:12px;box-shadow:0 2px 8px rgba(0,0,0,0.1);margin-bottom:20px}
.input-group{display:flex;gap:10px;margin-bottom:10px}
textarea{flex:1;min-height:100px;padding:12px;border:2px solid #e0e0e0;border-radius:8px;font-size:16px;resize:vertical}
button{background:#4f46e5;color:white;border:none;padding:12px 20px;border-radius:8px;font-size:16px;cursor:pointer;white-space:nowrap}
button:hover{background:#4338ca}button:disabled{background:#a5a5a3;cursor:not-allowed}
.result{margin-top:15px;padding:16px;background:#f0f9ff;border-radius:8px;display:none}
.result.show{display:block}
.tag{background:#e0e7ff;color:#3730a3;padding:6px 14px;border-radius:20px;font-size:14px;margin:4px;display:inline-flex;align-items:center;gap:6px}
.tag button{background:none;border:none;color:#3730a3;cursor:pointer;padding:0;font-size:16px;line-height:1}
.tag button:hover{color:#dc2626}
.note-item{padding:16px;border:1px solid #e5e7eb;border-radius:8px;margin-bottom:10px;cursor:pointer;transition:all 0.2s}
.note-item:hover{box-shadow:0 2px 8px rgba(0,0,0,0.1)}
.note-item.expanded{background:#f9fafb}
.note-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px}
.note-title{font-weight:600;font-size:16px;color:#1f2937;margin:0}
.note-date{color:#6b7280;font-size:12px}
.note-preview{color:#4b5563;font-size:14px;margin:8px 0}
.note-content{background:white;padding:12px;border-radius:6px;margin-top:8px;font-size:14px;line-height:1.6;border-left:3px solid #4f46e5}
.tag-selector{margin-top:12px;padding:12px;background:white;border-radius:8px}
.tag-selector h4{margin:0 0 8px 0;font-size:14px;color:#374151}
.tag-cloud{display:flex;flex-wrap:wrap;gap:8px}
.tag-option{padding:6px 12px;border:2px solid #e5e7eb;border-radius:20px;cursor:pointer;font-size:13px;transition:all 0.2s}
.tag-option:hover{border-color:#4f46e5}
.tag-option.selected{background:#4f46e5;color:white;border-color:#4f46e5}
h1,h2{margin:0 0 15px}
.error{color:#dc2626;margin-top:8px;font-size:14px}
.success{color:#059669;margin-top:8px;font-size:14px}
.loading{color:#6b7280;font-style:italic}
</style></head>
<body>

<div class="card">
  <h1>✨ QuickNote AI</h1>
  <div class="input-group">
    <textarea id="content" placeholder="Введите заметку..."></textarea>
    <button id="saveBtn" onclick="saveNote()">💾 Сохранить</button>
  </div>
  <div id="saveError" class="error"></div>
  
  <div class="result" id="saveResult">
    <h3 style="margin:0 0 10px">📝 Заметка сохранена!</h3>
    <div style="background:white;padding:12px;border-radius:6px;margin-bottom:12px;border-left:3px solid #4f46e5">
      <strong style="display:block;margin-bottom:6px;color:#1f2937" id="savedTitle"></strong>
      <div style="color:#4b5563;font-size:14px" id="savedContent"></div>
    </div>
    <div><strong>🏷️ Теги (нажмите для удаления):</strong><div class="tags" id="tags"></div></div>
    <div class="tag-selector">
      <h4>Добавить теги:</h4>
      <div class="tag-cloud" id="tagCloud"></div>
    </div>
    <div style="margin-top:12px"><strong>💡 Инсайт:</strong><p id="insight" style="margin:6px 0 0"></p></div>
    <button onclick="confirmTags()" style="margin-top:12px;width:100%">✅ Подтвердить теги</button>
  </div>
</div>

<div class="card">
  <h2>🔍 Умный поиск</h2>
  <div class="input-group">
    <input type="text" id="searchQuery" placeholder="Например: база данных, дедлайн...">
    <button id="searchBtn" onclick="searchNotes()">🔎 Найти</button>
  </div>
  <div id="searchError" class="error"></div>
  <div class="result" id="searchResult"></div>
  <div id="searchNotesList"></div>
</div>

<div class="card">
  <h2>📚 История заметок</h2>
  <div id="history"><span class="loading">Загрузка...</span></div>
</div>

<script>
let currentNoteId = null;
let currentTags = [];
let allAvailableTags = [];

// Загружаем доступные теги при старте
async function loadTags(){
  try{
    const r = await fetch("/api/tags");
    const d = await r.json();
    allAvailableTags = d.tags;
  }catch(e){console.error("Tags load error:",e)}
}

async function saveNote(){
  const content = document.getElementById("content").value.trim();
  const btn = document.getElementById("saveBtn");
  const errDiv = document.getElementById("saveError");
  if(!content){errDiv.textContent="Введите текст";return;}
  errDiv.textContent="";
  btn.disabled=true; btn.innerText="⏳ Сохраняем...";
  
  try{
    const resp = await fetch("/api/process",{
      method:"POST",
      headers:{"Content-Type":"application/json"},
      body:JSON.stringify({content:content})
    });
    const data = await resp.json();
    console.log("Save response:",data);
    
    if(!data.success){errDiv.textContent="Ошибка: "+(data.detail||"Неизвестно");return;}
    
    currentNoteId = data.id;
    currentTags = data.tags||[];
    
    // Показываем результат
    document.getElementById("savedTitle").textContent = data.title||"Заметка #"+data.id;
    document.getElementById("savedContent").textContent = data.content.length>200 ? data.content.substring(0,200)+"..." : data.content;
    document.getElementById("insight").textContent = data.insight||"💡 Инсайт";
    
    // Показываем теги с кнопками удаления
    const tagsDiv = document.getElementById("tags");
    tagsDiv.innerHTML = "";
    if(currentTags.length===0){
      tagsDiv.innerHTML = "<span style='color:#6b7280'>Теги не выбраны</span>";
    }else{
      currentTags.forEach(tag=>{
        const span = document.createElement("span");
        span.className = "tag";
        span.innerHTML = "#"+tag+' <button onclick="removeTag(\''+tag+'\')" title="Удалить">×</button>';
        tagsDiv.appendChild(span);
      });
    }
    
    // Показываем облако тегов для выбора
    renderTagCloud();
    
    document.getElementById("saveResult").classList.add("show");
    document.getElementById("content").value = "";
    loadHistory();
  }catch(e){
    console.error("Save error:",e);
    errDiv.textContent = "Ошибка: "+e.message;
  }finally{
    btn.disabled=false; btn.innerText="💾 Сохранить";
  }
}

function removeTag(tag){
  currentTags = currentTags.filter(t=>t!==tag);
  renderTags();
  renderTagCloud();
}

function addTag(tag){
  if(currentTags.length>=5){alert("Максимум 5 тегов");return;}
  if(!currentTags.includes(tag)){
    currentTags.push(tag);
    renderTags();
    renderTagCloud();
  }
}

function renderTags(){
  const tagsDiv = document.getElementById("tags");
  tagsDiv.innerHTML = "";
  if(currentTags.length===0){
    tagsDiv.innerHTML = "<span style='color:#6b7280'>Теги не выбраны</span>";
  }else{
    currentTags.forEach(tag=>{
      const span = document.createElement("span");
      span.className = "tag";
      span.innerHTML = "#"+tag+' <button onclick="removeTag(\''+tag+'\')" title="Удалить">×</button>';
      tagsDiv.appendChild(span);
    });
  }
}

function renderTagCloud(){
  const cloud = document.getElementById("tagCloud");
  cloud.innerHTML = "";
  allAvailableTags.forEach(tag=>{
    const btn = document.createElement("span");
    btn.className = "tag-option"+(currentTags.includes(tag)?" selected":"");
    btn.textContent = tag;
    btn.onclick = ()=>{
      if(currentTags.includes(tag)){
        currentTags = currentTags.filter(t=>t!==tag);
      }else{
        if(currentTags.length<5) currentTags.push(tag);
        else alert("Максимум 5 тегов");
      }
      renderTags();
      renderTagCloud();
    };
    cloud.appendChild(btn);
  });
}

async function confirmTags(){
  if(!currentNoteId)return;
  try{
    const resp = await fetch("/api/update-tags",{
      method:"POST",
      headers:{"Content-Type":"application/json"},
      body:JSON.stringify({content:JSON.stringify({id:currentNoteId,tags:currentTags})})
    });
    const data = await resp.json();
    if(data.success){
      document.getElementById("saveError").className = "success";
      document.getElementById("saveError").textContent = "✅ Теги обновлены!";
      setTimeout(()=>{
        document.getElementById("saveResult").classList.remove("show");
        document.getElementById("saveError").className = "error";
        document.getElementById("saveError").textContent = "";
      },2000);
      loadHistory();
    }
  }catch(e){
    alert("Ошибка сохранения тегов: "+e.message);
  }
}

async function searchNotes(){
  const query = document.getElementById("searchQuery").value.trim();
  const btn = document.getElementById("searchBtn");
  const errDiv = document.getElementById("searchError");
  if(!query){errDiv.textContent="Введите запрос";return;}
  errDiv.textContent="";
  btn.disabled=true; btn.innerText="⏳ Ищем...";
  document.getElementById("searchResult").classList.remove("show");
  document.getElementById("searchNotesList").innerHTML="";
  
  try{
    const resp = await fetch("/api/search",{
      method:"POST",
      headers:{"Content-Type":"application/json"},
      body:JSON.stringify({query:query})
    });
    const data = await resp.json();
    console.log("Search response:",data);
    
    if(!data.success){
      document.getElementById("searchResult").textContent="🔍 "+data.message;
      document.getElementById("searchResult").classList.add("show");
      return;
    }
    
    document.getElementById("searchResult").textContent=data.answer||"Найдено записей";
    document.getElementById("searchResult").classList.add("show");
    
    if(data.notes && data.notes.length>0){
      let html="";
      data.notes.forEach(n=>{
        const tagsStr = (n.tags&&n.tags.join)?n.tags.join(", "):"";
        html+="<div class='note-item' onclick='viewNote("+n.id+")'><div class='note-header'><div class='note-title'>"+(n.title||"Без заголовка")+"</div><div class='note-date'>"+(n.created_at||"").substring(0,10)+"</div></div><div class='note-preview'>"+(n.content||"").substring(0,150)+"...</div><div style='margin-top:6px'><span style='color:#6b7280;font-size:12px'>🏷️ "+tagsStr+"</span></div></div>";
      });
      document.getElementById("searchNotesList").innerHTML=html;
    }
  }catch(e){
    console.error("Search error:",e);
    errDiv.textContent="Ошибка: "+e.message;
  }finally{
    btn.disabled=false; btn.innerText="🔎 Найти";
  }
}

async function viewNote(id){
  try{
    const resp = await fetch("/api/notes/"+id);
    const note = await resp.json();
    
    // Разворачиваем/сворачиваем
    const items = document.querySelectorAll(".note-item");
    items.forEach(item=>{
      if(item.onclick&&item.onclick.toString().includes(id)){
        item.classList.toggle("expanded");
        if(item.classList.contains("expanded")){
          const tagsStr = (note.tags&&note.tags.join)?note.tags.join(", "):"";
          item.innerHTML="<div class='note-header'><div class='note-title'>"+(note.title||"Без заголовка")+"</div><div class='note-date'>"+(note.created_at||"").substring(0,10)+"</div></div><div class='note-content'>"+note.content+"</div><div style='margin-top:8px'><span style='color:#6b7280;font-size:12px'>🏷️ "+tagsStr+"</span></div>"+(note.insight?"<div style='margin-top:8px;color:#059669;font-size:13px'>💡 "+note.insight+"</div>":"");
        }else{
          // Сворачиваем обратно
          item.innerHTML="<div class='note-header'><div class='note-title'>"+(note.title||"Без заголовка")+"</div><div class='note-date'>"+(note.created_at||"").substring(0,10)+"</div></div><div class='note-preview'>"+(note.content||"").substring(0,150)+"...</div><div style='margin-top:6px'><span style='color:#6b7280;font-size:12px'>🏷️ "+((note.tags&&note.tags.join)?note.tags.join(", "):"")+"</span></div>";
        }
      }
    });
  }catch(e){
    console.error("View error:",e);
    alert("Ошибка загрузки заметки");
  }
}

async function loadHistory(){
  const histDiv = document.getElementById("history");
  try{
    const resp = await fetch("/api/notes");
    const data = await resp.json();
    console.log("History:",data);
    
    if(!data||data.length===0){
      histDiv.innerHTML="<span class='loading'>Пока пусто</span>";
      return;
    }
    
    let html="";
    data.forEach(n=>{
      const tagsStr = (n.tags&&n.tags.join)?n.tags.join(", "):"";
      html+="<div class='note-item' onclick='viewNote("+n.id+")'><div class='note-header'><div class='note-title'>"+(n.title||"Без заголовка")+"</div><div class='note-date'>"+(n.created_at||"").substring(0,10)+"</div></div><div class='note-preview'>"+(n.content||"").substring(0,150)+"...</div><div style='margin-top:6px'><span style='color:#6b7280;font-size:12px'>🏷️ "+tagsStr+"</span></div></div>";
    });
    histDiv.innerHTML=html;
  }catch(e){
    console.error("History error:",e);
    histDiv.innerHTML="<span class='loading'>Ошибка загрузки</span>";
  }
}

// Инициализация
loadTags();
loadHistory();
</script></body></html>"""

@app.get("/", response_class=HTMLResponse)
async def home(): return HTML
